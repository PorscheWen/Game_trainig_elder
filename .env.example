# LINE Push 推播（Messaging API Channel）
LINE_CHANNEL_ACCESS_TOKEN=your_messaging_api_access_token

# 推播目標用戶 ID（LINE User ID）
LINE_USER_ID=your_line_user_id

# 遊戲 GitHub Pages 網址
GAME_URL=https://porschewen.github.io/GrannysGotGame/

# 團體榜：server.js 轉發 GitHub repository_dispatch（Fine-grained PAT：Contents+Actions 或 classic repo）
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=GrannysGotGame
GITHUB_DISPATCH_TOKEN=
